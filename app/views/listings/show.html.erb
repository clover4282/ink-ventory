<% content_for :title, "#{@listing.title.presence || '상품 정보 확인 중'} - Ink-ventory" %>
<% status_labels = { "in_stock" => "재고 있음", "out_of_stock" => "품절", "removed" => "판매 종료", "unknown" => "확인 중" } %>
<% event_labels = { "RESTOCKED" => "재입고", "SOLD_OUT" => "품절", "PRICE_CHANGED" => "가격 변경" } %>

<%= link_to "← 상품 목록으로", root_path, class: "muted" %>
<div class="flash notice" data-like-notice tabindex="-1" hidden></div>

<section class="listing-detail panel">
  <% if @listing.image_url.present? %>
    <div class="product-image-link"><%= image_tag @listing.image_url, alt: @listing.title, class: "product-image", referrerpolicy: "no-referrer" %></div>
  <% else %>
    <div class="product-image-link product-image-placeholder">이미지 수집 중</div>
  <% end %>

  <div class="detail-copy">
    <% logo_url = SiteRegistry.logo_url(@listing.site.code) %>
    <span class="shop"><%= image_tag logo_url, alt: "", class: "shop-logo", referrerpolicy: "no-referrer" if logo_url %><%= @listing.site.name %></span>
    <h1><%= @listing.title.presence || "상품 정보 확인 중" %></h1>
    <span class="card-badges"><% if @listing.created_at >= 30.days.ago %><span class="status new-badge">NEW</span><% end %><span class="status <%= @listing.status == 'in_stock' ? 'good' : 'warning' %>"><%= status_labels.fetch(@listing.status, "확인 중") %></span></span>
    <p class="price"><%= @listing.display_price ? "#{@listing.display_price}원" : "가격 확인 중" %></p>
    <p class="muted">마지막 정상 확인: <%= @listing.last_success_at ? l(@listing.last_success_at, format: :long) : "아직 없음" %></p>
    <p class="muted" data-detail-view-count data-listing-id="<%= @listing.id %>" data-view-count="<%= @listing.clicks_count %>">조회수 <%= @listing.clicks_count %></p>
    <div class="product-actions">
      <% like_data = { like_button: true } %>
      <% if current_user&.verified_for_notifications? %>
        <% like_data[:like_url] = like_listing_path(@listing) %>
      <% elsif current_user %>
        <% like_data[:like_email_required] = true %>
      <% else %>
        <% like_data[:like_login_required] = true %>
      <% end %>
      <%= button_tag type: "button", class: "like-button#{' liked' if @liked}", data: like_data, aria: { pressed: @liked } do %><span data-like-icon><%= @liked ? "♥" : "♡" %></span> 관심 <span data-like-count><%= @listing.likes_count %></span><% end %>
      <% if (purchase_url = safe_listing_url(@listing)) %>
        <%= link_to "판매처에서 구매하기", purchase_url, target: "_blank", rel: "noopener", class: "button primary" %>
      <% end %>
    </div>
    <p class="muted like-explanation">관심 상품으로 등록하면 재입고·품절·가격 변동을 즉시 인증한 이메일로 알려드립니다.</p>
  </div>
</section>

<section class="detail-history">
  <div class="section-title"><h2>재고·가격 변화</h2><span class="muted">확정된 변화 <%= @change_events.size %>건</span></div>
  <% if @change_events.empty? %>
    <div class="empty">아직 확인된 재고·가격 변화가 없습니다.</div>
  <% else %>
    <div class="change-list">
      <% @change_events.each do |event| %>
        <% before = event.previous_value["value"] %>
        <% after = event.current_value["value"] %>
        <% before_text = event.kind == "PRICE_CHANGED" ? "#{number_with_delimiter(before)}원" : status_labels.fetch(before, before.to_s) %>
        <% after_text = event.kind == "PRICE_CHANGED" ? "#{number_with_delimiter(after)}원" : status_labels.fetch(after, after.to_s) %>
        <article class="change-event panel" data-change-event="<%= event.kind %>">
          <header><strong><%= event_labels.fetch(event.kind) %></strong><time datetime="<%= event.occurred_at.iso8601 %>" class="muted"><%= l(event.occurred_at, format: :long) %></time></header>
          <p><%= before_text %> → <%= after_text %></p>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
