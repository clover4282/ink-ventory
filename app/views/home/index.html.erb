<% unless current_user %>
  <section class="hero">
    <p class="eyebrow">FOUNTAIN PEN STOCK WATCH</p>
    <h1>찾던 만년필이 돌아오는 순간,<br><span>놓치지 마세요.</span></h1>
    <p>베스트펜·블루블랙·펜갤러리아·펜로그의 만년필 재고와 가격 변화를 한곳에서 확인하고 이메일로 받아보세요.</p>
    <%= render "catalog_search", compact: true %>
    <div class="email-login">
      <%= form_with url: login_path do |form| %>
        <%= form.email_field :email, value: session[:login_email], required: true, autocomplete: "email", placeholder: "이메일 주소", aria: { label: "로그인 이메일" } %>
        <%= form.submit "인증번호 받기", class: "button primary" %>
      <% end %>
      <% if session[:login_email].present? %>
        <%= form_with url: verify_login_path, class: "email-code-form" do |form| %>
          <%= form.hidden_field :email, value: session[:login_email] %>
          <%= form.text_field :code, required: true, inputmode: "numeric", autocomplete: "one-time-code", maxlength: 6, pattern: "[0-9]{6}", placeholder: "6자리 인증번호", aria: { label: "6자리 인증번호" } %>
          <%= form.submit "로그인", class: "button primary" %>
        <% end %>
      <% end %>
      <% if Rails.env.local? %><%= button_to "개발자 모드로 시작하기", development_login_path, class: "button secondary" %><% end %>
    </div>
  </section>
  <%= render "crawled_listings" %>
<% else %>
  <section class="welcome">
    <div><p class="eyebrow">FOUNTAIN PEN SEARCH</p><h1><%= current_user.name %>님의 만년필 찾기</h1></div>
    <% if current_user.verified_for_notifications? %>
      <span class="status good">● <%= current_user.notification_address.email %> 인증됨</span>
    <% else %>
      <%= link_to "알림 이메일 인증 필요", edit_notification_address_path, class: "status warning" %>
    <% end %>
  </section>

  <%= render "catalog_search" %>
  <%= render "crawled_listings" %>

  <details class="danger-zone"><summary>계정 관리</summary><p>탈퇴하면 로그인 이메일, 구독 및 개인 발송 기록이 삭제됩니다.</p><%= button_to "회원 탈퇴", account_path, method: :delete, class: "button danger", form: { data: { turbo_confirm: "정말 탈퇴할까요?" } } %></details>
<% end %>
