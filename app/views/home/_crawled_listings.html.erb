<section data-catalog-results>
  <div class="flash notice catalog-notice" data-catalog-notice tabindex="-1" hidden></div>
  <div class="catalog-controls panel" data-catalog-controls>
    <label>판매처
      <select data-catalog-control data-filter-site><option value="">전체 판매처</option><%= options_from_collection_for_select(@catalog_sites, :id, :name) %></select>
    </label>
    <label>재고 상태
      <select data-catalog-control data-filter-status><option value="">전체 상태</option><option value="in_stock">재고 있음</option><option value="out_of_stock">품절</option></select>
    </label>
    <label>최소 가격
      <input type="number" min="0" step="1000" placeholder="0원" data-catalog-control data-filter-min-price>
    </label>
    <label>최대 가격
      <input type="number" min="0" step="1000" placeholder="제한 없음" data-catalog-control data-filter-max-price>
    </label>
    <label class="checkbox catalog-restocked"><input type="checkbox" data-catalog-control data-filter-restocked> 최근 10일 재입고</label>
    <label>정렬
      <select data-catalog-control data-catalog-sort>
        <option value="relevance">기본·검색 정확도순</option>
        <option value="popularity">인기도순</option>
        <option value="newest">최신 등록순</option>
        <option value="likes">좋아요순</option>
        <option value="price_asc">가격 낮은순</option>
        <option value="price_desc">가격 높은순</option>
        <option value="restocked">최근 재입고순</option>
      </select>
    </label>
  </div>
  <div class="section-title">
    <h2 data-catalog-title><%= @catalog_query.present? ? "검색 결과 #{@crawled_listing_count}개" : "현재 수집 만년필 #{@crawled_listing_count}개" %></h2>
    <span class="muted"><span data-catalog-summary><%= @catalog_query.present? ? "“#{@catalog_query}” · " : "최근 정상 확인순 최대 50개" %></span><%= link_to "전체 보기", root_path, data: { catalog_clear: true }, hidden: @catalog_query.blank? %></span>
  </div>
  <div class="empty" data-catalog-empty <%= "hidden" if @crawled_listing_count.positive? %>><%= @catalog_query.present? ? "검색 결과가 없습니다." : "아직 정상 수집된 상품이 없습니다." %></div>
  <div class="cards" data-catalog-cards <%= "hidden" if @crawled_listing_count.zero? %>>
      <% visible_count = 0 %>
      <% @crawled_listings.each do |listing| %>
        <% search_text = "#{listing.title} #{listing.site.name}".unicode_normalize(:nfc).downcase %>
        <% restocked_at = @recent_restocked_at[listing.id] %>
        <% liked = @liked_listing_ids.key?(listing.id) %>
        <% matches = @catalog_query.blank? || CatalogSearch.match?(search_text, @catalog_query) %>
        <% visible = matches && visible_count < 50 %>
        <% visible_count += 1 if matches %>
        <article class="product-card" data-catalog-card data-search-text="<%= search_text %>" data-listing-id="<%= listing.id %>" data-site-id="<%= listing.site_id %>" data-status="<%= listing.status %>" data-price="<%= listing.base_price_cents %>" data-created-at="<%= listing.created_at.to_i %>" data-restocked-at="<%= restocked_at&.to_i || 0 %>" data-clicks="<%= listing.clicks_count %>" data-likes="<%= listing.likes_count %>" <%= "hidden" unless visible %>>
          <% if listing.image_url.present? %>
            <%= link_to listing.canonical_url, target: "_blank", rel: "noopener", class: "product-image-link", data: { track_click: click_listing_path(listing) } do %>
              <%= image_tag listing.image_url, alt: listing.title, class: "product-image", loading: "lazy", referrerpolicy: "no-referrer" %>
            <% end %>
          <% else %>
            <div class="product-image-link product-image-placeholder">이미지 수집 중</div>
          <% end %>
          <% logo_url = SiteRegistry.logo_url(listing.site.code) %>
          <div class="card-top"><span class="shop"><%= image_tag logo_url, alt: "", class: "shop-logo", loading: "lazy", referrerpolicy: "no-referrer" if logo_url %><%= listing.site.name %></span><span class="status <%= listing.status == 'in_stock' ? 'good' : 'warning' %>"><%= {"in_stock" => "재고 있음", "out_of_stock" => "품절", "removed" => "판매 종료"}.fetch(listing.status, "확인 중") %></span></div>
          <h3><%= link_to listing.title, listing.canonical_url, target: "_blank", rel: "noopener", data: { product_title: listing.title, track_click: click_listing_path(listing) } %></h3>
          <p class="price"><%= listing.display_price ? "#{listing.display_price}원" : "가격 확인 중" %></p>
          <p class="muted">마지막 정상 확인: <%= l(listing.last_success_at, format: :long) %></p>
          <div class="product-actions">
            <% like_data = { like_button: true } %>
            <% if current_user&.verified_for_notifications? %>
              <% like_data[:like_url] = like_listing_path(listing) %>
            <% elsif current_user %>
              <% like_data[:like_email_required] = true %>
            <% else %>
              <% like_data[:like_login_required] = true %>
            <% end %>
            <%= button_tag type: "button", class: "like-button#{' liked' if liked}", data: like_data, aria: { pressed: liked } do %><span data-like-icon><%= liked ? "♥" : "♡" %></span> 관심 <span data-like-count><%= listing.likes_count %></span><% end %>
            <span class="muted">조회수 <span data-click-count><%= listing.clicks_count %></span></span>
            <% if restocked_at %><span class="status good">10일 내 재입고</span><% end %>
          </div>
        </article>
      <% end %>
  </div>
</section>
