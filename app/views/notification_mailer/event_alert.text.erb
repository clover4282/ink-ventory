<%= event_label(@event.kind) %> - <%= @event.listing.title %> / <%= @event.listing.site.name %>
이전: <%= formatted_value(@event.previous_value["value"]) %>
현재: <%= formatted_value(@event.current_value["value"]) %>
발생 시각: <%= l(@event.occurred_at, format: :long) %>
<% if (product_url = SiteRegistry.safe_external_url(@event.listing.canonical_url)) %>상품: <%= product_url %>
<% end %>
전체 알림 중지: <%= unsubscribe_notification_address_url(token: @address.unsubscribe_token) %>
