<section class="welcome"><div><p class="eyebrow">OPERATIONS</p><h1>운영 현황</h1></div></section>
<section class="panel"><h2>사이트 수집 스위치</h2>
  <% @sites.each do |site| %><%= form_with url: admin_site_path(site), method: :patch, class: "inline-form" do |form| %><strong><%= site.name %></strong><span>실패 <%= site.consecutive_failures %>회 · 백오프 <%= site.backoff_until || "없음" %></span><%= form.hidden_field :enabled, value: site.enabled? ? 0 : 1 %><%= form.submit site.enabled? ? "긴급 중지" : "수집 재개", class: "button small #{'danger' if site.enabled?}" %><% end %><% end %>
</section>
<section class="panel"><h2>파서·수집 오류</h2><table><thead><tr><th>사이트</th><th>상품</th><th>연속 오류</th><th>마지막 확인</th></tr></thead><tbody><% @failed_listings.each do |listing| %><tr><td><%= listing.site.name %></td><td><%= listing.title || listing.canonical_url %></td><td><%= listing.consecutive_errors %></td><td><%= listing.last_checked_at %></td></tr><% end %></tbody></table></section>
<section class="panel"><h2>최근 발송 대기열</h2><table><thead><tr><th>시각</th><th>종류</th><th>상태</th><th>시도</th><th>오류</th></tr></thead><tbody><% @mail_deliveries.each do |delivery| %><tr><td><%= delivery.created_at %></td><td><%= delivery.kind %></td><td><%= delivery.status %></td><td><%= delivery.attempts %></td><td><%= delivery.last_error %></td></tr><% end %></tbody></table></section>
